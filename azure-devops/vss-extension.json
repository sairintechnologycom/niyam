{
    "manifestVersion": 1,
    "id": "niyam-governance",
    "version": "0.1.0",
    "name": "Niyam Governance",
    "description": "Governed autonomous development for AI coding agents.",
    "publisher": "SairinTechnology",
    "targets": [
        {
            "id": "Microsoft.VisualStudio.Services"
        }
    ],
    "icons": {
        "default": "images/icon.png"
    },
    "categories": [
        "Azure Pipelines"
    ],
    "content": {
        "details": {
            "path": "README.md"
        }
    },
    "contributions": [
        {
            "id": "niyam-verify-task",
            "type": "ms.vss-distributed-task.task",
            "targets": [
                "ms.vss-distributed-task.tasks"
            ],
            "properties": {
                "name": "NiyamVerify"
            }
        }
    ],
    "files": [
        {
            "path": "NiyamVerify",
            "packagePath": "NiyamVerify"
        }
    ]
}
