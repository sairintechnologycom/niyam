{
  "hooks": {
    "pre_tool_use": [
      {
        "matcher": {
          "tool_name": "bash"
        },
        "hook": {
          "type": "command",
          "command": "python .claude/hooks/pre_tool_guard.py"
        }
      },
      {
        "matcher": {
          "tool_name": "shell"
        },
        "hook": {
